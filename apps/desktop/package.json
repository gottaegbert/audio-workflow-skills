{
  "name": "@vocalflow/desktop",
  "version": "0.1.3",
  "description": "Desktop app for generating vocal stems, karaoke assets, and subtitles with audio-subtitles.",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "packageManager": "pnpm@10.20.0",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5174 && tsc -p tsconfig.electron.json && electron .\"",
    "dev:ui": "vite --host 127.0.0.1",
    "build": "pnpm run build:ui && pnpm run build:main",
    "build:ui": "vite build",
    "build:main": "tsc -p tsconfig.electron.json",
    "dist": "pnpm run build && electron-builder --publish never",
    "dist:mac": "pnpm run build && electron-builder --mac dmg --publish never",
    "dist:win": "pnpm run build && electron-builder --win nsis --publish never",
    "start": "electron ."
  },
  "build": {
    "appId": "com.gottaegbert.vocalflow",
    "productName": "VocalFlow Studio",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../skills/audio-subtitles/scripts",
        "to": "audio-subtitles/scripts",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "vendor/python-runtime",
        "to": "python-runtime",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "node_modules/ffmpeg-static",
        "to": "ffmpeg-static",
        "filter": [
          "ffmpeg",
          "ffmpeg.exe"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.music",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.0",
    "electron": "^37.0.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "wait-on": "^8.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild",
      "ffmpeg-static"
    ]
  }
}
